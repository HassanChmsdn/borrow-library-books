# Server-only variables
# DATABASE_URL=
# APP_BASE_URL=http://localhost:3000

# Application environment
# Use `local` for local Docker/desktop MongoDB, `development` or `staging` for shared environments,
# and `production` for the deployed app.
# APP_ENV=local

# MongoDB
# Local example:
# MONGODB_URI=mongodb://127.0.0.1:27017
# MONGODB_DB_NAME=borrow-library-books
# MONGODB_DIRECT_CONNECTION=true

# Atlas/shared environment example:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB_NAME=borrow-library-books
# MONGODB_DIRECT_CONNECTION=false

# Optional connection tuning for either local or Atlas setups.
# Keep these unset unless your environment needs them.
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=8000
# MONGODB_TLS=
# MONGODB_TLS_ALLOW_INVALID_CERTIFICATES=
# MONGODB_TLS_ALLOW_INVALID_HOSTNAMES=

# Auth0
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret
# AUTH0_SECRET=generate-a-32-byte-hex-secret

# Client-exposed variables must be prefixed with NEXT_PUBLIC_
# NEXT_PUBLIC_APP_URL=http://localhost:3000